# Database configuration
# For Docker Compose setup, use: mysql+pymysql://receptionist_user:receptionist_pass@db:3306/restaurant_db
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/restaurant_db

# Ollama configuration
# For Docker Compose setup, use: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Application configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
